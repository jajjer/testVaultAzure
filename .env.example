# --- Frontend (Vite) ---
# API is proxied to http://127.0.0.1:3001 in dev (see vite.config.ts). Leave empty for same-origin in production.
VITE_API_BASE_URL=

# Microsoft Entra ID (SPA app registration)
VITE_AZURE_AD_CLIENT_ID=
VITE_AZURE_AD_TENANT_ID=
# API scope exposed by your API app registration (must match AZURE_AD_AUDIENCE / scope)
VITE_AZURE_AD_API_SCOPE=

# Optional overrides (defaults: current origin)
# VITE_MSAL_REDIRECT_URI=
# VITE_MSAL_POST_LOGOUT_REDIRECT_URI=

# Local dev without Entra: set both frontend and API SKIP flags, run `npm run dev` + `npm run dev:api`
# VITE_SKIP_AUTH=true
# Optional JSON for X-TestVault-Dev-User (defaults to a generic dev user)
# VITE_DEV_USER_JSON={"uid":"dev-user-1","email":"dev@localhost","displayName":"Dev User"}
