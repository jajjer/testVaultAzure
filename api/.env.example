PORT=3001

# Azure SQL (connection string from Key Vault in production)
AZURE_SQL_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Database=testvault;User ID=...;Password=...;Encrypt=true

# Entra ID — API app registration (validate JWTs from SPA)
AZURE_AD_TENANT_ID=
# Audience: Application ID URI of the API app (e.g. api://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
AZURE_AD_AUDIENCE=

# Optional: Azure Blob Storage (attachment SAS URLs)
# AZURE_STORAGE_CONNECTION_STRING=

# Local development only — trust X-TestVault-Dev-User (never enable in production)
# SKIP_AUTH=true
